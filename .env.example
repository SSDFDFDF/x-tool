# X-Tool runtime environment example

# Server
X_TOOL_PORT=8026
X_TOOL_HOST=0.0.0.0
X_TOOL_TIMEOUT=180

# Log output
X_TOOL_LOG_PATH=logs/app.log
X_TOOL_LOG_MAX_SIZE_MB=100
X_TOOL_LOG_MAX_BACKUPS=5

# Admin
# Required for admin login
X_TOOL_ADMIN_PASSWORD=change-me

# Database
# Supported values: sqlite, postgres
X_TOOL_DB_DRIVER=sqlite

# PostgreSQL DSN example:
# postgres://x-tool:password@127.0.0.1:5432/x-tool?sslmode=disable
# Leave empty when using sqlite
X_TOOL_DB_DSN=

# SQLite file path (ignored when X_TOOL_DB_DRIVER=postgres)
X_TOOL_DB_PATH=data.db

# First-run seed defaults (only used when DB tables are empty)
X_TOOL_DEFAULT_CLIENT_KEY=sk-x-tool-dev
